---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = await getCollection('notes');
notes.sort((a, b) => b.data.date.localeCompare(a.data.date));

const [featured, ...rest] = notes;
---

<BaseLayout
  title="Field Notes · Vignesh K"
  description="Field notes: why I built each thing, the one decision that mattered, what I learned."
>
  <section class="notes-page shell">
    <div class="notes-page__head animate-fade-in-up">
      <p class="section-label">Field Notes</p>
      <h1>Writing about<br />the work.</h1>
      <p class="lead">
        Why something got built, the one decision that mattered, what I learned.
      </p>
    </div>

    {featured && (
      <a class="note-featured animate-fade-in-up delay-1" href={`/notes/${featured.slug}`}>
        <div class="note-featured__meta">
          <span class="note-featured__label">Latest</span>
          <span class="note-featured__date">{featured.data.dateLabel}</span>
          <span class="tag">{featured.data.roomLabel}</span>
          <span class="note-featured__words">{featured.data.words} words</span>
        </div>
        <h2>{featured.data.title}</h2>
        <p>{featured.data.dek}</p>
        <span class="note-featured__link">Read →</span>
      </a>
    )}

    <div class="notes-divider"></div>

    <div class="notes-list">
      {rest.map((n) => (
        <a class="note-row animate-fade-in-up" href={`/notes/${n.slug}`}>
          <div class="note-row__main">
            <div class="note-row__meta">
              <span>{n.data.dateLabel}</span>
              <span class="note-row__sep">·</span>
              <span class="note-row__room">{n.data.roomLabel}</span>
              <span class="note-row__sep">·</span>
              <span>{n.data.words} words</span>
            </div>
            <h3>{n.data.title}</h3>
            <p>{n.data.dek}</p>
          </div>
          <span class="note-row__arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <style>
    .notes-page {
      padding: var(--s-10) 0 var(--s-12);
      max-width: 800px;
      margin: 0 auto;
    }
    .notes-page__head {
      margin-bottom: var(--s-10);
    }
    .notes-page__head h1 {
      font-family: var(--font-display);
      font-size: clamp(42px, 5.5vw, 72px);
      font-weight: 400;
      line-height: 1.05;
      color: var(--ink);
      margin-bottom: var(--s-4);
      letter-spacing: -0.03em;
    }
    .notes-page__head .lead {
      font-size: 18px;
      line-height: 1.6;
      color: var(--ink-soft);
      max-width: 480px;
    }

    .note-featured {
      display: flex;
      flex-direction: column;
      gap: var(--s-3);
      padding: var(--s-7) var(--s-8);
      background: var(--bg-soft);
      border: 1px solid var(--hairline);
      border-radius: 20px;
      margin-bottom: var(--s-8);
      transition: transform var(--ease), box-shadow var(--ease), border-color var(--ease);
    }
    .note-featured:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 48px color-mix(in oklch, var(--ink) 5%, transparent);
      border-color: var(--accent);
    }
    .note-featured__meta {
      display: flex;
      align-items: center;
      gap: var(--s-3);
      flex-wrap: wrap;
      margin-bottom: var(--s-1);
    }
    .note-featured__label {
      font-size: var(--t-tiny);
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .note-featured__date {
      font-size: var(--t-small);
      color: var(--muted);
    }
    .note-featured__words {
      font-size: var(--t-small);
      color: var(--muted);
    }
    .note-featured h2 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3.5vw, 40px);
      font-weight: 400;
      line-height: 1.15;
      color: var(--ink);
    }
    .note-featured p {
      font-size: 17px;
      line-height: 1.6;
      color: var(--ink-soft);
      max-width: 580px;
    }
    .note-featured__link {
      font-size: var(--t-small);
      font-weight: 600;
      color: var(--accent);
      margin-top: var(--s-2);
      transition: color var(--ease);
    }
    .note-featured:hover .note-featured__link {
      color: var(--accent-hover);
    }

    .notes-divider {
      height: 1px;
      background: var(--hairline);
      margin-bottom: var(--s-6);
    }

    .notes-list {
      display: flex;
      flex-direction: column;
    }
    .note-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--s-5);
      padding: var(--s-6) 0;
      border-bottom: 1px solid var(--hairline);
      transition: padding var(--ease);
    }
    .note-row:last-child {
      border-bottom: none;
    }
    .note-row:hover {
      padding-left: var(--s-2);
      padding-right: var(--s-2);
      margin: 0 calc(-1 * var(--s-2));
      background: var(--bg-soft);
      border-radius: 12px;
      border-bottom-color: transparent;
    }
    .note-row:hover + .note-row {
      border-top: 1px solid transparent;
      margin-top: -1px;
    }
    .note-row__main {
      display: flex;
      flex-direction: column;
      gap: var(--s-2);
      flex: 1;
    }
    .note-row__meta {
      display: flex;
      align-items: center;
      gap: var(--s-2);
      font-size: var(--t-small);
      color: var(--muted);
      flex-wrap: wrap;
    }
    .note-row__sep {
      color: var(--muted-2);
    }
    .note-row__room {
      color: var(--accent);
      font-weight: 500;
    }
    .note-row h3 {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 400;
      line-height: 1.25;
      color: var(--ink);
      transition: color var(--ease);
    }
    .note-row:hover h3 {
      color: var(--accent);
    }
    .note-row p {
      font-size: var(--t-body);
      line-height: 1.55;
      color: var(--ink-soft);
      max-width: 540px;
    }
    .note-row__arrow {
      font-size: var(--t-body);
      color: var(--muted-2);
      transition: transform var(--ease), color var(--ease);
      padding-top: 6px;
      flex-shrink: 0;
    }
    .note-row:hover .note-row__arrow {
      transform: translateX(4px);
      color: var(--accent);
    }

    @media (max-width: 720px) {
      .note-featured {
        padding: var(--s-5) var(--s-6);
      }
      .note-row h3 {
        font-size: 20px;
      }
    }
  </style>
</BaseLayout>
